# API keys for flight-slate. Copy to env.flight-slate.local.sh on the Pi
# and fill in real values. The .local.sh file is gitignored so secrets
# can't be lost to a `git reset --hard` or accidentally committed.

# AirLabs schedules API: https://airlabs.co/dashboard
export AIRLABS_API_KEY=

# Flightradar24 API: https://fr24api.flightradar24.com/key-management
export FR24_API_KEY=

# Optional: Mapbox token for the map page.
# export MAPBOX_TOKEN=
